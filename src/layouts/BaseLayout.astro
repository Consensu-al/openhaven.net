---
import '../styles/global.css';
import Nav from '@/components/ui/Nav.astro';
import Footer from '@/components/ui/Footer.astro';
import ContributeBanner from '@/components/ui/ContributeBanner.astro';
import { useTranslations } from '@/i18n';

export interface BaseLayoutProps {
  title: string;
  description?: string;
  ogImage?: string;
}

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);

const {
  title,
  description = t('meta.defaultDescription') as string,
  ogImage,
} = Astro.props as BaseLayoutProps;

const pageTitle = title.includes('OpenHaven') ? title : `${title} — OpenHaven`;
const siteBase = (Astro.site ?? new URL('https://openhaven.net')).toString().replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, siteBase);

const currentPath = Astro.url.pathname;
const enPath = currentPath.startsWith('/pt-BR') ? currentPath.replace(/^\/pt-BR/, '') || '/' : currentPath;
const ptBRPath = currentPath.startsWith('/pt-BR') ? currentPath : `/pt-BR${currentPath}`;
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={new URL(enPath, siteBase)} />
    <link rel="alternate" hreflang="pt-BR" href={new URL(ptBRPath, siteBase)} />
    <link rel="alternate" hreflang="x-default" href={new URL(enPath, siteBase)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <slot name="head" />
  </head>
  <body>
    <Nav locale={locale} />
    <slot />
    <Footer locale={locale} />
    <ContributeBanner locale={locale} />
  </body>
</html>
