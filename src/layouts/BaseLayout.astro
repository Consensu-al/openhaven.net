---
import '../styles/global.css';
import Nav from '@/components/ui/Nav.astro';
import Footer from '@/components/ui/Footer.astro';

export interface BaseLayoutProps {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'OpenHaven — Discover, compare, and choose open protocols for the decentralized web.',
  ogImage,
} = Astro.props as BaseLayoutProps;

const pageTitle = title.includes('OpenHaven') ? title : `${title} — OpenHaven`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://openhaven.net');
---

<!DOCTYPE html>
<html lang={Astro.currentLocale ?? 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <slot name="head" />
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />
  </body>
</html>
