---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations } from '@/i18n';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);
const prefix = locale !== 'en' ? `/${locale}` : '';
---

<BaseLayout
  title={t('home.title') as string}
  description={t('home.description') as string}
>
  <main>
    <section class="hero-section">
      <div class="container">
        <h1 class="hero-title">{t('home.heroTitle')}</h1>
        <p class="hero-tagline">{t('home.heroTagline')}</p>
      </div>
    </section>

    <section class="content-section">
      <div class="container">
        <h2>{t('home.buildingTogetherHeading')}</h2>
        <p>{t('home.buildingTogetherBody')}</p>
        <ul class="principles-list">
          {(t('home.principles') as string[]).map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="content-section navigator-section">
      <div class="container">
        <h2 class="navigable-heading">{t('home.navigableHeading')} <span class="new-pill">{t('home.newBadge')}</span></h2>
        <p>{t('home.navigableBody1')}</p>
        <p>{t('home.navigableBody2')}</p>
        <div class="cta-group">
          <a href={`${prefix}/prototype`} class="cta cta-primary">
            {t('home.explorePrototype')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href={`${prefix}/brief`} class="cta cta-secondary">
            {t('home.readBrief')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero-section {
    padding: 6rem 1rem 3rem;
    text-align: center;
    background: var(--color-brand-accent-light);
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-brand-primary);
    margin: 0 0 1rem 0;
    line-height: 1.1;
  }

  .hero-tagline {
    font-size: 1.25rem;
    color: var(--color-brand-text);
    margin: 0;
    opacity: 0.8;
  }

  .content-section {
    padding: 3rem 1rem 3rem;
  }

  .content-section:last-child {
    padding-bottom: 5rem;
  }

  .navigator-section {
    border-top: 1px solid rgba(139, 69, 19, 0.1);
  }

  .cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .cta:hover {
    opacity: 0.9;
    border-bottom: none;
  }

  .cta-primary {
    color: white;
    background: var(--color-brand-primary);
  }

  .cta-secondary {
    color: var(--color-brand-primary);
    background: transparent;
    border: 2px solid var(--color-brand-primary);
  }

  .content-section h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-brand-primary);
    margin: 0 0 1.25rem 0;
  }

  .content-section p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-brand-text);
    max-width: 65ch;
    margin: 0 0 1.25rem 0;
  }

  .principles-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .principles-list li {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-brand-text);
    padding-left: 1.5rem;
    position: relative;
  }

  .principles-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-brand-accent);
  }

  .navigable-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .new-pill {
    display: inline-flex;
    align-items: center;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    color: var(--color-brand-primary);
    background-color: var(--color-brand-accent-light);
    border: 1px solid rgba(139, 69, 19, 0.2);
    opacity: 0.8;
    flex-shrink: 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 4rem;
    }

    .hero-tagline {
      font-size: 1.5rem;
    }
  }
</style>
