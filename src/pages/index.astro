---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroSection from "@/components/sections/HeroSection.astro";
import PrinciplesSection from "@/components/sections/PrinciplesSection.astro";
import DisclaimerBanner from "@/components/sections/DisclaimerBanner.astro";
import NavigatorSection from "@/components/islands/NavigatorSection";
import { loadDomains, loadAffordances, loadProtocols } from "@/lib/data";

const domains = loadDomains();
const affordances = loadAffordances();
const protocols = loadProtocols();

const principles = [
  {
    title: "Start from Need",
    description: "Enter through real-world use cases like Communication, Identity, or Mutual Aid — not technical jargon.",
  },
  {
    title: "Understand What Matters",
    description: "See plain-language affordances that explain technical capabilities in terms of what they enable for you.",
  },
  {
    title: "Find Your Stack",
    description: "Arrive at verified protocols with governance, risk, and community context so you can choose with confidence.",
  },
  {
    title: "Connect & Build",
    description: "Connect with the protocol's community and start building, manually or with preset AI prompts.",
  },
];
---

<BaseLayout
  title="OpenHaven — Navigate the Open Protocol Landscape"
  description="OpenHaven maps the open protocol landscape so builders, coalitions, and communities can discover verified tools through human needs — not technical jargon."
>
  <HeroSection
    title="Navigate the Open Protocol"
    highlight="Landscape"
    subtitle="Discover verified protocols organized by real-world needs — not technical jargon. Built for builders, coalitions, and communities shaping the decentralized web."
    badge="MVP — Real data, growing"
    primaryCta={{ label: "Find Your Stack", href: "#navigator" }}
    secondaryCta={{ label: "Browse Full Registry", href: "/registry" }}
  />

  <PrinciplesSection
    heading="How OpenHaven Works"
    subheading="Open protocols, organized by what matters to you."
    principles={principles}
  />

  <DisclaimerBanner
    message="Alpha — data coverage is incomplete and unverified. Unmapped areas are visible gaps, not omissions."
    ctaLabel="Help us grow"
    ctaHref="/contribute"
  />

  <section id="navigator" class="section-padding">
    <div class="container">
      <NavigatorSection client:load domains={domains} affordances={affordances} protocols={protocols} locale="en" />
    </div>
  </section>
</BaseLayout>
