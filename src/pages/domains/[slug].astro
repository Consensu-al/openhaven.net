---
import { loadDomains, loadProtocolsByDomain, loadAffordancesByDomain } from '@/lib/data'
import type { Domain, Protocol, Affordance } from '@/lib/types'
import BaseLayout from '@/layouts/BaseLayout.astro'

export function getStaticPaths() {
  const domains = loadDomains()
  return domains.map((domain) => ({
    params: { slug: domain.slug },
    props: { domain },
  }))
}

const { domain } = Astro.props as { domain: Domain }
const protocols = loadProtocolsByDomain(domain.id)
const affordances = loadAffordancesByDomain(domain.slug)

// Date formatting
const locale = Astro.currentLocale ?? 'en'
const dateFormatter = new Intl.DateTimeFormat(locale, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
})

// --- UI Strings ---
const LABELS = {
  governance: {
    foundation: 'Foundation',
    dao: 'DAO',
    'single-company': 'Company',
    'open-standard-body': 'Open Standard',
    community: 'Community',
  } as Record<Protocol['governanceModel'], string>,
  architecture: {
    'fully-p2p': 'Fully P2P',
    federated: 'Federated',
    hybrid: 'Hybrid',
  } as Record<Protocol['architectureType'], string>,
  captureRisk: {
    low: 'Low capture risk',
    medium: 'Medium capture risk',
    high: 'High capture risk',
  } as Record<Protocol['captureRisk'], string>,
}

const RISK_COLOR: Record<Protocol['captureRisk'], string> = {
  low: '#22c55e',
  medium: '#f59e0b',
  high: '#ef4444',
}

// --- Domain Icon SVGs ---
const DOMAIN_ICON_SVGS: Record<string, string> = {
  'scan-face': '<path d="M3 7V5a2 2 0 0 1 2-2h2" /><path d="M17 3h2a2 2 0 0 1 2 2v2" /><path d="M21 17v2a2 2 0 0 1-2 2h-2" /><path d="M7 21H5a2 2 0 0 1-2-2v-2" /><path d="M8 14s1.5 2 4 2 4-2 4-2" /><path d="M9 9h.01" /><path d="M15 9h.01" />',
  'message-circle': '<path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719" />',
  'users': '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><path d="M16 3.128a4 4 0 0 1 0 7.744" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><circle cx="9" cy="7" r="4" />',
  'heart-handshake': '<path d="M19.414 14.414C21 12.828 22 11.5 22 9.5a5.5 5.5 0 0 0-9.591-3.676.6.6 0 0 1-.818.001A5.5 5.5 0 0 0 2 9.5c0 2.3 1.5 4 3 5.5l5.535 5.362a2 2 0 0 0 2.879.052 2.12 2.12 0 0 0-.004-3 2.124 2.124 0 1 0 3-3 2.124 2.124 0 0 0 3.004 0 2 2 0 0 0 0-2.828l-1.881-1.882a2.41 2.41 0 0 0-3.409 0l-1.71 1.71a2 2 0 0 1-2.828 0 2 2 0 0 1 0-2.828l2.823-2.762" />',
  'lightbulb': '<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" /><path d="M9 18h6" /><path d="M10 22h4" />',
  'calendar': '<path d="M8 2v4" /><path d="M16 2v4" /><rect width="18" height="18" x="3" y="4" rx="2" /><path d="M3 10h18" />',
  'helping-hand': '<path d="M11 12h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 14" /><path d="m7 18 1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a2 2 0 0 0-2.75-2.91l-4.2 3.9" /><path d="m2 13 6 6" />',
  'graduation-cap': '<path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z" /><path d="M22 10v6" /><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5" />',
  'shield-check': '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" /><path d="m9 12 2 2 4-4" />',
  'map-pin': '<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" /><circle cx="12" cy="10" r="3" />',
}

const iconSvg = DOMAIN_ICON_SVGS[domain.icon] ?? ''

// --- SEO ---
const META_DESC_MAX = 155
const affordanceNames = affordances.slice(0, 3).map((a) => a.name).join(', ')
const metaParts = [
  `${domain.name}: ${domain.description}`,
  `${protocols.length} open protocols`,
  affordanceNames ? `Key affordances: ${affordanceNames}` : null,
].filter(Boolean)
const fullDescription = metaParts.join(' — ')
const pageDescription = fullDescription.length <= META_DESC_MAX
  ? fullDescription
  : `${fullDescription.slice(0, META_DESC_MAX - 1)}…`
---

<BaseLayout title={`${domain.name} — OpenHaven`} description={pageDescription}>
  <main class="domain-detail">
    <div class="container">

      <!-- Top Nav: Back to Navigator -->
      <nav class="top-nav">
        <a href="/#navigator" class="back-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Back to Navigator
        </a>
      </nav>

      <!-- Hero Card -->
      <div class="hero-card">
        <div class="hero-content">
          <!-- Left: Icon, Title, Description -->
          <div class="hero-main">
            <div class="hero-title-row">
              {iconSvg && (
                <div class="domain-icon" aria-hidden="true">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="28"
                    height="28"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <Fragment set:html={iconSvg} />
                  </svg>
                </div>
              )}
              <h1 class="hero-title">{domain.name}</h1>
              <span class="entity-badge">Use Case Domain</span>
            </div>

            <p class="hero-description">{domain.description}</p>

            <!-- Stats Row -->
            <div class="stats-row">
              <span class="stat-item">
                <strong>{protocols.length}</strong> protocol{protocols.length !== 1 ? 's' : ''}
              </span>
              <span class="stat-divider">·</span>
              <span class="stat-item">
                <strong>{affordances.length}</strong> affordance{affordances.length !== 1 ? 's' : ''}
              </span>
            </div>
          </div>

          <!-- Right: Actions -->
          <div class="hero-actions">
            <a href={`/?useCase=${domain.slug}`} class="action-btn action-btn--primary">
              Explore in Navigator
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Content Grid -->
      <div class="content-grid">

        <!-- Left: Affordances -->
        {affordances.length > 0 && (
          <div class="content-card">
            <h2 class="section-title">Affordances</h2>
            <p class="section-subtitle">Capabilities protocols in this domain may provide</p>
            <div class="tags-list">
              {affordances.map((affordance) => (
                <span class="tag tag--affordance">
                  {affordance.name}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Right: Quick Stats -->
        <div class="content-card">
          <h2 class="section-title">Overview</h2>
          <div class="overview-list">
            <div class="overview-row">
              <span class="overview-label">Primary Domain</span>
              <span class="overview-value">{domain.isPrimary ? 'Yes' : 'No'}</span>
            </div>
            <div class="overview-row">
              <span class="overview-label">Protocols Mapped</span>
              <span class="overview-value">{protocols.length}</span>
            </div>
            <div class="overview-row">
              <span class="overview-label">Affordances</span>
              <span class="overview-value">{affordances.length}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Protocols Section -->
      <div class="protocols-section">
        <h2 class="section-title-large">Protocols in {domain.name}</h2>

        {protocols.length === 0 ? (
          <p class="no-protocols">No protocols mapped yet for this domain.</p>
        ) : (
          <div class="protocols-grid">
            {protocols.map((protocol) => {
              const dateFormatted = dateFormatter.format(new Date(protocol.lastInvestigated))
              return (
                <a href={`/protocols/${protocol.id}`} class="protocol-card">
                  <div class="protocol-header">
                    <h3 class="protocol-name">{protocol.name}</h3>
                    <span class="protocol-entity">{protocol.entityType}</span>
                  </div>

                  {protocol.description && (
                    <p class="protocol-desc">{protocol.description}</p>
                  )}

                  <div class="protocol-badges">
                    <span class="badge badge--architecture">
                      {LABELS.architecture[protocol.architectureType]}
                    </span>
                    <span class="badge badge--governance">
                      {LABELS.governance[protocol.governanceModel]}
                    </span>
                    <span class="badge badge--risk">
                      <span class="risk-dot" style={`background-color: ${RISK_COLOR[protocol.captureRisk]}`}></span>
                      {LABELS.captureRisk[protocol.captureRisk]}
                    </span>
                  </div>

                  <div class="protocol-footer">
                    <span class="protocol-date">Last investigated: {dateFormatted}</span>
                    <span class="protocol-cta">
                      View Details
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M7 17L17 7M17 7H7M17 7v10"/>
                      </svg>
                    </span>
                  </div>
                </a>
              )
            })}
          </div>
        )}
      </div>

    </div>
  </main>
</BaseLayout>

<style>
  .domain-detail {
    padding: 1.5rem 1rem 4rem;
    background: var(--color-brand-bg);
    min-height: 100vh;
  }

  .container {
    max-width: 64rem;
    margin: 0 auto;
  }

  /* Top Nav */
  .top-nav {
    margin-bottom: 1.25rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-brand-primary);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }

  .back-link:hover {
    opacity: 1;
  }

  /* Hero Card */
  .hero-card {
    background: white;
    border: 2px solid rgba(139, 69, 19, 0.25);
    border-radius: 1rem;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .hero-content {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .hero-main {
    flex: 1;
    min-width: 0;
  }

  .hero-title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .domain-icon {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.75rem;
    background: var(--color-brand-accent-light);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-primary);
    flex-shrink: 0;
  }

  .hero-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-brand-primary);
    margin: 0;
    line-height: 1.2;
  }

  @media (min-width: 640px) {
    .hero-title {
      font-size: 1.75rem;
    }
  }

  .entity-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-brand-primary);
    background: var(--color-brand-accent-light);
    border: 1px solid rgba(139, 69, 19, 0.2);
    border-radius: 9999px;
  }

  .hero-description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-brand-text);
    margin: 0 0 1rem 0;
    max-width: 55ch;
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.8125rem;
    color: var(--color-brand-text);
  }

  .stat-item strong {
    color: var(--color-brand-primary);
    font-weight: 600;
  }

  .stat-divider {
    opacity: 0.3;
  }

  /* Hero Actions */
  .hero-actions {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .action-btn--primary {
    color: white;
    background: var(--color-brand-primary);
  }

  .action-btn--primary:hover {
    opacity: 0.9;
  }

  /* Content Grid */
  .content-grid {
    display: grid;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .content-card {
    background: white;
    border: 2px solid rgba(139, 69, 19, 0.25);
    border-radius: 1rem;
    padding: 1.25rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-brand-primary);
    margin: 0 0 0.25rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .section-subtitle {
    font-size: 0.75rem;
    color: var(--color-brand-text);
    opacity: 0.6;
    margin: 0 0 1rem 0;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 0.5rem;
  }

  .tag--affordance {
    color: var(--color-brand-text);
    background: white;
    border: 2px solid rgba(139, 69, 19, 0.25);
  }

  /* Overview List */
  .overview-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .overview-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(139, 69, 19, 0.1);
  }

  .overview-row:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .overview-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-brand-text);
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .overview-value {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-brand-primary);
  }

  /* Protocols Section */
  .protocols-section {
    margin-top: 2rem;
  }

  .section-title-large {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-brand-primary);
    margin: 0 0 1.25rem 0;
  }

  .no-protocols {
    font-size: 0.875rem;
    color: var(--color-brand-text);
    opacity: 0.6;
  }

  .protocols-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .protocols-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Protocol Card */
  .protocol-card {
    display: flex;
    flex-direction: column;
    background: white;
    border: 2px solid rgba(139, 69, 19, 0.25);
    border-radius: 1rem;
    padding: 1.25rem;
    text-decoration: none;
    transition: all 0.15s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .protocol-card:hover {
    border-color: var(--color-brand-primary);
    box-shadow: 0 8px 24px rgba(139, 69, 19, 0.12);
  }

  .protocol-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .protocol-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-brand-primary);
    margin: 0;
  }

  .protocol-entity {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-brand-primary);
    background: var(--color-brand-accent-light);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
  }

  .protocol-desc {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-brand-text);
    opacity: 0.8;
    margin: 0 0 0.75rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .protocol-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.75rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 500;
    border-radius: 0.375rem;
  }

  .badge--architecture {
    color: var(--color-brand-primary);
    background: transparent;
    border: 1px solid rgba(139, 69, 19, 0.25);
  }

  .badge--governance {
    color: var(--color-brand-primary);
    background: var(--color-brand-accent-light);
  }

  .badge--risk {
    color: var(--color-brand-text);
    background: transparent;
    border: 1px solid var(--color-card-border);
  }

  .risk-dot {
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .protocol-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(139, 69, 19, 0.1);
  }

  .protocol-date {
    font-size: 0.6875rem;
    color: var(--color-brand-text);
    opacity: 0.5;
  }

  .protocol-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-brand-primary);
  }
</style>
