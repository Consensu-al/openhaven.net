---
import { loadDomains, loadProtocolsByDomain, loadAffordancesByDomain } from '@/lib/data'
import type { Domain, Protocol, Affordance } from '@/lib/types'
import BaseLayout from '@/layouts/BaseLayout.astro'

export function getStaticPaths() {
  const domains = loadDomains()
  return domains.map((domain) => ({
    params: { slug: domain.slug },
    props: { domain },
  }))
}

const { domain } = Astro.props as { domain: Domain }
const protocols = loadProtocolsByDomain(domain.id)
const affordances = loadAffordancesByDomain(domain.slug)

// Date formatting (locale-aware for future i18n support)
const locale = Astro.currentLocale ?? 'en'
const dateFormatter = new Intl.DateTimeFormat(locale, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
})

// --- UI Strings (i18n-ready) ---
const DOMAIN_PAGE_STRINGS = {
  breadcrumbHome: 'Home',
  breadcrumbDomains: 'Domains',
  exploreInNavigator: 'Explore in Navigator',
  protocolsInDomain: 'Protocols in this Domain',
  affordancesLabel: 'Key Affordances',
  protocolCount: `${protocols.length} protocol${protocols.length !== 1 ? 's' : ''}`,
  noProtocols: 'No protocols mapped yet for this domain.',
  lastInvestigated: 'Last investigated',
  viewDetails: 'View Details',
  governanceLabel: {
    foundation: 'Foundation',
    dao: 'DAO',
    'single-company': 'Company',
    'open-standard-body': 'Open Standard',
    community: 'Community',
  } as Record<Protocol['governanceModel'], string>,
  architectureLabel: {
    'fully-p2p': 'Fully P2P',
    federated: 'Federated',
    hybrid: 'Hybrid',
  } as Record<Protocol['architectureType'], string>,
  captureRiskLabel: {
    low: 'Low capture risk',
    medium: 'Medium capture risk',
    high: 'High capture risk',
  } as Record<Protocol['captureRisk'], string>,
} as const

// --- Badge Style Maps (reused from protocol detail) ---
const GOVERNANCE_STYLE: Record<Protocol['governanceModel'], { bg: string; text: string }> = {
  foundation: { bg: 'var(--color-badge-foundation-bg)', text: 'var(--color-badge-foundation-text)' },
  dao: { bg: 'var(--color-badge-dao-bg)', text: 'var(--color-badge-dao-text)' },
  'single-company': { bg: 'var(--color-badge-company-bg)', text: 'var(--color-badge-company-text)' },
  'open-standard-body': { bg: 'var(--color-badge-standard-bg)', text: 'var(--color-badge-standard-text)' },
  community: { bg: 'var(--color-badge-community-bg)', text: 'var(--color-badge-community-text)' },
}

const RISK_COLOR: Record<Protocol['captureRisk'], string> = {
  low: 'var(--color-risk-low)',
  medium: 'var(--color-risk-medium)',
  high: 'var(--color-risk-high)',
}

const ARCH_STYLE: Record<Protocol['architectureType'], { border: string; text: string }> = {
  'fully-p2p': { border: 'var(--color-arch-p2p-bg)', text: 'var(--color-arch-p2p-text)' },
  federated: { border: 'var(--color-arch-federated-bg)', text: 'var(--color-arch-federated-text)' },
  hybrid: { border: 'var(--color-arch-hybrid-bg)', text: 'var(--color-arch-hybrid-text)' },
}

// --- Domain Icon SVGs (inline, no JS needed) ---
const DOMAIN_ICON_SVGS: Record<string, string> = {
  'scan-face': '<path d="M3 7V5a2 2 0 0 1 2-2h2" /><path d="M17 3h2a2 2 0 0 1 2 2v2" /><path d="M21 17v2a2 2 0 0 1-2 2h-2" /><path d="M7 21H5a2 2 0 0 1-2-2v-2" /><path d="M8 14s1.5 2 4 2 4-2 4-2" /><path d="M9 9h.01" /><path d="M15 9h.01" />',
  'message-circle': '<path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719" />',
  'users': '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><path d="M16 3.128a4 4 0 0 1 0 7.744" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><circle cx="9" cy="7" r="4" />',
  'heart-handshake': '<path d="M19.414 14.414C21 12.828 22 11.5 22 9.5a5.5 5.5 0 0 0-9.591-3.676.6.6 0 0 1-.818.001A5.5 5.5 0 0 0 2 9.5c0 2.3 1.5 4 3 5.5l5.535 5.362a2 2 0 0 0 2.879.052 2.12 2.12 0 0 0-.004-3 2.124 2.124 0 1 0 3-3 2.124 2.124 0 0 0 3.004 0 2 2 0 0 0 0-2.828l-1.881-1.882a2.41 2.41 0 0 0-3.409 0l-1.71 1.71a2 2 0 0 1-2.828 0 2 2 0 0 1 0-2.828l2.823-2.762" />',
  'lightbulb': '<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" /><path d="M9 18h6" /><path d="M10 22h4" />',
  'calendar': '<path d="M8 2v4" /><path d="M16 2v4" /><rect width="18" height="18" x="3" y="4" rx="2" /><path d="M3 10h18" />',
  'helping-hand': '<path d="M11 12h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 14" /><path d="m7 18 1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a2 2 0 0 0-2.75-2.91l-4.2 3.9" /><path d="m2 13 6 6" />',
  'graduation-cap': '<path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z" /><path d="M22 10v6" /><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5" />',
  'shield-check': '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" /><path d="m9 12 2 2 4-4" />',
  'map-pin': '<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" /><circle cx="12" cy="10" r="3" />',
}

const iconSvg = DOMAIN_ICON_SVGS[domain.icon] ?? ''

// --- SEO ---
const META_DESC_MAX = 155
const affordanceNames = affordances.slice(0, 3).map((a) => a.name).join(', ')
const metaParts = [
  `${domain.name}: ${domain.description}`,
  `${protocols.length} open protocols`,
  affordanceNames ? `Key affordances: ${affordanceNames}` : null,
].filter(Boolean)
const fullDescription = metaParts.join(' — ')
const pageDescription = fullDescription.length <= META_DESC_MAX
  ? fullDescription
  : `${fullDescription.slice(0, META_DESC_MAX - 1)}…`

// --- JSON-LD ---
const siteBase = (Astro.site ?? new URL('https://openhaven.net')).toString().replace(/\/$/, '')
const canonicalUrl = `${siteBase}/domains/${domain.slug}`

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  'name': `${domain.name} — Open Protocols`,
  'description': domain.description,
  'url': canonicalUrl,
  'mainEntity': {
    '@type': 'ItemList',
    'name': `Open protocols for ${domain.name}`,
    'numberOfItems': protocols.length,
    'itemListElement': protocols.map((protocol, index) => ({
      '@type': 'ListItem',
      'position': index + 1,
      'name': protocol.name,
      'url': `${siteBase}/protocols/${protocol.id}`,
    })),
  },
}

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': siteBase },
    { '@type': 'ListItem', 'position': 2, 'name': 'Domains', 'item': `${siteBase}/domains` },
    { '@type': 'ListItem', 'position': 3, 'name': domain.name, 'item': canonicalUrl },
  ],
}
---

<BaseLayout title={`${domain.name} — OpenHaven`} description={pageDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([jsonLd, breadcrumbLd])} />
  </Fragment>

  <main class="section-padding">
    <div class="container">

      {/* Breadcrumb */}
      <nav aria-label="Breadcrumb" class="mb-6 text-sm" data-testid="breadcrumb">
        <ol class="flex flex-wrap items-center gap-1" style="color: var(--color-brand-text); opacity: 0.7;">
          <li>
            <a
              href="/"
              class="min-h-[44px] min-w-[44px] inline-flex items-center underline-offset-2 hover:underline"
              style="color: var(--color-brand-primary); border-bottom: none;"
              data-testid="breadcrumb-home"
            >
              {DOMAIN_PAGE_STRINGS.breadcrumbHome}
            </a>
          </li>
          <li aria-hidden="true">&gt;</li>
          <li>
            <span>{DOMAIN_PAGE_STRINGS.breadcrumbDomains}</span>
          </li>
          <li aria-hidden="true">&gt;</li>
          <li aria-current="page">
            <span style="color: var(--color-brand-text);">{domain.name}</span>
          </li>
        </ol>
      </nav>

      {/* Domain Header */}
      <div
        class="rounded-lg p-6 sm:p-8 mb-8"
        style="background-color: var(--color-domain-selected-bg);"
        data-testid="domain-header"
      >
        <div class="flex items-start gap-4">
          {iconSvg && (
            <div class="shrink-0 mt-1" aria-hidden="true" data-testid="domain-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="color: var(--color-brand-primary);"
              >
                <Fragment set:html={iconSvg} />
              </svg>
            </div>
          )}
          <div>
            <h1 class="text-2xl sm:text-3xl lg:text-4xl mb-2" data-testid="domain-name">
              {domain.name}
            </h1>
            <p class="text-base mb-0" style="color: var(--color-brand-text); max-width: 65ch;" data-testid="domain-description">
              {domain.description}
            </p>
          </div>
        </div>

        <div class="mt-6">
          <a
            href={`/?useCase=${domain.slug}`}
            class="inline-flex items-center gap-2 px-5 py-3 rounded-lg text-sm font-semibold min-h-[44px] min-w-[44px] transition-colors"
            style="background-color: var(--color-brand-primary); color: var(--color-brand-bg); border-bottom: none;"
            data-testid="explore-navigator-cta"
          >
            {DOMAIN_PAGE_STRINGS.exploreInNavigator} &rarr;
          </a>
        </div>
      </div>

      {/* Affordances */}
      {affordances.length > 0 && (
        <div class="mb-8" data-testid="affordances-section">
          <h2 class="text-lg font-semibold mb-3 mt-0">
            {DOMAIN_PAGE_STRINGS.affordancesLabel}
          </h2>
          <div class="flex flex-wrap gap-2">
            {affordances.map((affordance) => (
              <span
                class="text-xs px-3 py-1.5 rounded-full min-h-[44px] inline-flex items-center"
                style="background-color: var(--color-chip-unchecked-bg); color: var(--color-brand-text); border: 1px solid var(--color-card-border);"
                data-testid={`affordance-pill-${affordance.id}`}
              >
                {affordance.name}
              </span>
            ))}
          </div>
        </div>
      )}

      {/* Protocols */}
      <div data-testid="protocols-section">
        <h2 class="text-lg font-semibold mb-1 mt-0">
          {DOMAIN_PAGE_STRINGS.protocolsInDomain}
        </h2>
        <p class="text-sm mb-4" style="color: var(--color-brand-text); opacity: 0.7;">
          {DOMAIN_PAGE_STRINGS.protocolCount}
        </p>

        {protocols.length === 0 ? (
          <p class="text-sm" style="color: var(--color-brand-text); opacity: 0.6;" data-testid="no-protocols">
            {DOMAIN_PAGE_STRINGS.noProtocols}
          </p>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {protocols.map((protocol) => {
              const govStyle = GOVERNANCE_STYLE[protocol.governanceModel]
              const riskColor = RISK_COLOR[protocol.captureRisk]
              const archStyle = ARCH_STYLE[protocol.architectureType]
              const dateFormatted = dateFormatter.format(new Date(protocol.lastInvestigated))

              return (
                <a
                  href={`/protocols/${protocol.id}`}
                  class="block rounded-lg p-4 sm:p-6 transition-shadow hover:shadow-md"
                  style="background-color: var(--color-card-bg); border: 1px solid var(--color-card-border); border-bottom: 1px solid var(--color-card-border);"
                  data-testid={`protocol-entry-${protocol.id}`}
                >
                  <h3 class="font-semibold text-lg mb-2 mt-0" style="color: var(--color-brand-primary);">
                    {protocol.name}
                  </h3>
                  <div class="flex flex-wrap gap-2 mb-3">
                    {/* Architecture badge — outline */}
                    <span
                      class="text-xs px-2 py-0.5 rounded-full border"
                      style={`color: ${archStyle.text}; border-color: ${archStyle.border}; background-color: transparent;`}
                    >
                      {DOMAIN_PAGE_STRINGS.architectureLabel[protocol.architectureType]}
                    </span>
                    {/* Governance badge — filled */}
                    <span
                      class="text-xs px-2 py-0.5 rounded-full"
                      style={`background-color: ${govStyle.bg}; color: ${govStyle.text};`}
                    >
                      {DOMAIN_PAGE_STRINGS.governanceLabel[protocol.governanceModel]}
                    </span>
                    {/* Capture risk */}
                    <span class="inline-flex items-center gap-1.5 text-xs">
                      <span
                        class="inline-block w-2.5 h-2.5 rounded-full"
                        style={`background-color: ${riskColor};`}
                        aria-hidden="true"
                      ></span>
                      <span style="color: var(--color-brand-text);">
                        {DOMAIN_PAGE_STRINGS.captureRiskLabel[protocol.captureRisk]}
                      </span>
                    </span>
                  </div>
                  <p class="text-sm mt-2 mb-0" style="color: var(--color-brand-text); opacity: 0.7;">
                    {DOMAIN_PAGE_STRINGS.lastInvestigated}: {dateFormatted}
                  </p>
                </a>
              )
            })}
          </div>
        )}
      </div>

      {/* Back to Navigator */}
      <div class="pt-6 mt-8 border-t" style="border-color: var(--color-card-border);">
        <a
          href="/#navigator"
          class="inline-flex items-center gap-1 text-sm min-h-[44px] min-w-[44px] underline-offset-2 hover:underline"
          style="color: var(--color-brand-primary); border-bottom: none;"
          data-testid="back-to-navigator"
        >
          &larr; {DOMAIN_PAGE_STRINGS.breadcrumbHome}
        </a>
      </div>

    </div>
  </main>
</BaseLayout>
