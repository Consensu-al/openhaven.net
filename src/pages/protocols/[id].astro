---
import { loadProtocols, loadDomains, loadAffordances } from '@/lib/data'
import type { Protocol, Domain, Affordance } from '@/lib/types'
import BaseLayout from '@/layouts/BaseLayout.astro'

export function getStaticPaths() {
  const protocols = loadProtocols()
  return protocols.map((protocol) => ({
    params: { id: protocol.id },
    props: { protocol },
  }))
}

const { protocol } = Astro.props as { protocol: Protocol }
const domains = loadDomains()
const affordances = loadAffordances()

// Lookup maps
const domainMap = new Map<string, Domain>(domains.map((d) => [d.id, d]))
const affordanceMap = new Map<string, Affordance>(affordances.map((a) => [a.id, a]))

// Resolve names
const protocolDomains = protocol.domainIds
  .map((id) => domainMap.get(id))
  .filter((d): d is Domain => d !== undefined)
const protocolAffordances = protocol.affordanceIds
  .map((id) => affordanceMap.get(id))
  .filter((a): a is Affordance => a !== undefined)

// Date formatting
const locale = Astro.currentLocale ?? 'en'
const dateFormatted = new Intl.DateTimeFormat(locale, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).format(new Date(protocol.lastInvestigated))

// UI Strings
const LABELS = {
  governance: {
    foundation: 'Foundation',
    dao: 'DAO',
    'single-company': 'Company',
    'open-standard-body': 'Open Standard',
    community: 'Community',
  } as Record<Protocol['governanceModel'], string>,
  architecture: {
    'fully-p2p': 'Fully P2P',
    federated: 'Federated',
    hybrid: 'Hybrid',
  } as Record<Protocol['architectureType'], string>,
  captureRisk: {
    low: 'Low capture risk',
    medium: 'Medium capture risk',
    high: 'High capture risk',
  } as Record<Protocol['captureRisk'], string>,
}

const RISK_COLOR: Record<Protocol['captureRisk'], string> = {
  low: '#22c55e',
  medium: '#f59e0b',
  high: '#ef4444',
}

// Key Attributes
type KeyAttribute = { label: string; value: string }
const keyAttributes: KeyAttribute[] = [
  protocol.license ? { label: 'License', value: protocol.license } : null,
  protocol.devStatus ? { label: 'Dev Status', value: protocol.devStatus } : null,
  protocol.owner ? { label: 'Owner', value: protocol.owner } : null,
  protocol.country ? { label: 'Country', value: protocol.country } : null,
  protocol.startYear ? { label: 'Start Year', value: String(protocol.startYear) } : null,
  protocol.stack.length > 0 ? { label: 'Stack', value: protocol.stack.join(', ') } : null,
  protocol.funding.length > 0 ? { label: 'Funding', value: protocol.funding.join(', ') } : null,
  { label: 'Last Investigated', value: dateFormatted },
].filter((attr): attr is KeyAttribute => attr !== null)

// SEO
const META_DESC_MAX = 155
const fullDescription = `${protocol.description ?? protocol.name} — ${LABELS.architecture[protocol.architectureType]} architecture, ${LABELS.governance[protocol.governanceModel]} governance`
const pageDescription = fullDescription.length <= META_DESC_MAX
  ? fullDescription
  : `${fullDescription.slice(0, META_DESC_MAX - 1)}…`

// Links
const hasWebsite = protocol.website
const hasCommunity = protocol.communityLink
const hasLinks = hasWebsite || hasCommunity
---

<BaseLayout title={`${protocol.name} — OpenHaven`} description={pageDescription}>
  <main class="protocol-detail">
    <div class="container">

      <!-- Top Nav: Back to Navigator -->
      <nav class="top-nav">
        <a href="/#navigator" class="back-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Back to Navigator
        </a>
      </nav>

      <!-- Hero Card -->
      <div class="hero-card">
        <div class="hero-content">
          <!-- Left: Title, badge, description -->
          <div class="hero-main">
            <div class="hero-title-row">
              <h1 class="hero-title">{protocol.name}</h1>
              <span class="entity-badge">{protocol.entityType}</span>
            </div>

            {protocol.description && (
              <p class="hero-description">{protocol.description}</p>
            )}

            <!-- Badge Row -->
            <div class="badge-row">
              <span class="badge badge--architecture">
                {LABELS.architecture[protocol.architectureType]}
              </span>
              <span class="badge badge--governance">
                {LABELS.governance[protocol.governanceModel]}
              </span>
              <span class="badge badge--risk">
                <span class="risk-dot" style={`background-color: ${RISK_COLOR[protocol.captureRisk]}`}></span>
                {LABELS.captureRisk[protocol.captureRisk]}
              </span>
            </div>
          </div>

          <!-- Right: Links -->
          {hasLinks && (
            <div class="hero-links">
              <span class="links-label">Links</span>
              <div class="links-list">
                {hasWebsite && (
                  <a href={protocol.website} target="_blank" rel="noopener noreferrer" class="link-btn">
                    Visit Website
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M7 17L17 7M17 7H7M17 7v10"/>
                    </svg>
                  </a>
                )}
                {hasCommunity && (
                  <a href={protocol.communityLink} target="_blank" rel="noopener noreferrer" class="link-btn">
                    Visit Community
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M7 17L17 7M17 7H7M17 7v10"/>
                    </svg>
                  </a>
                )}
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Main Content Grid -->
      <div class="content-grid">

        <!-- Left Column: Attributes -->
        <div class="attributes-card">
          <h2 class="section-title">Details</h2>
          <div class="attributes-list">
            {keyAttributes.map((attr) => (
              <div class="attribute-row">
                <span class="attribute-label">{attr.label}</span>
                <span class="attribute-value">{attr.value}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right Column: Domains & Affordances -->
        <div class="tags-column">
          {protocolDomains.length > 0 && (
            <div class="tags-card">
              <h2 class="section-title">Use Case Domains</h2>
              <div class="tags-list">
                {protocolDomains.map((domain) => (
                  <a href={`/domains/${domain.slug}`} class="tag tag--domain">
                    {domain.name}
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M7 17L17 7M17 7H7M17 7v10"/>
                    </svg>
                  </a>
                ))}
              </div>
            </div>
          )}

          {protocolAffordances.length > 0 && (
            <div class="tags-card">
              <h2 class="section-title">Affordances</h2>
              <div class="tags-list">
                {protocolAffordances.map((affordance) => (
                  <span class="tag tag--affordance">
                    {affordance.name}
                  </span>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>

    </div>
  </main>
</BaseLayout>

<style>
  .protocol-detail {
    padding: 1.5rem 1rem 4rem;
    background: var(--color-brand-bg);
    min-height: 100vh;
  }

  .container {
    max-width: 56rem;
    margin: 0 auto;
  }

  /* Top Nav */
  .top-nav {
    margin-bottom: 1.25rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-brand-primary);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }

  .back-link:hover {
    opacity: 1;
  }

  /* Hero Card */
  .hero-card {
    background: white;
    border: 2px solid rgba(139, 69, 19, 0.25);
    border-radius: 1rem;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .hero-content {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .hero-main {
    flex: 1;
    min-width: 0;
  }

  .hero-title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .hero-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-brand-primary);
    margin: 0;
    line-height: 1.2;
  }

  @media (min-width: 640px) {
    .hero-title {
      font-size: 1.75rem;
    }
  }

  .entity-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-brand-primary);
    background: var(--color-brand-accent-light);
    border: 1px solid rgba(139, 69, 19, 0.2);
    border-radius: 9999px;
  }

  .hero-description {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-brand-text);
    margin: 0 0 1rem 0;
    max-width: 50ch;
  }

  /* Badge Row */
  .badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: 0.5rem;
  }

  .badge--architecture {
    color: var(--color-brand-primary);
    background: transparent;
    border: 2px solid rgba(139, 69, 19, 0.25);
  }

  .badge--governance {
    color: var(--color-brand-primary);
    background: var(--color-brand-accent-light);
    border: 1px solid rgba(139, 69, 19, 0.15);
  }

  .badge--risk {
    color: var(--color-brand-text);
    background: transparent;
    border: 1px solid var(--color-card-border);
  }

  .risk-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Hero Links */
  .hero-links {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.25rem;
  }

  @media (min-width: 640px) {
    .hero-links {
      align-items: flex-end;
      min-width: 140px;
    }
  }

  .links-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-brand-text);
    opacity: 0.5;
    margin-bottom: 0.25rem;
  }

  .links-list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-brand-primary);
    background: var(--color-brand-accent-light);
    border: 1px solid rgba(139, 69, 19, 0.2);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .link-btn:hover {
    background: var(--color-domain-selected-bg);
    border-color: var(--color-brand-primary);
  }

  /* Content Grid */
  .content-grid {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Attributes Card */
  .attributes-card {
    background: white;
    border: 2px solid rgba(139, 69, 19, 0.25);
    border-radius: 1rem;
    padding: 1.25rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-brand-primary);
    margin: 0 0 1rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .attributes-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .attribute-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(139, 69, 19, 0.1);
  }

  .attribute-row:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .attribute-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-brand-text);
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }

  .attribute-value {
    font-size: 0.8125rem;
    color: var(--color-brand-text);
    text-align: right;
  }

  /* Tags Column */
  .tags-column {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tags-card {
    background: white;
    border: 2px solid rgba(139, 69, 19, 0.25);
    border-radius: 1rem;
    padding: 1.25rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .tag--domain {
    color: var(--color-brand-primary);
    background: var(--color-brand-accent-light);
    border: 1px solid rgba(139, 69, 19, 0.2);
  }

  .tag--domain:hover {
    background: var(--color-domain-selected-bg);
    border-color: var(--color-brand-primary);
  }

  .tag--affordance {
    color: var(--color-brand-text);
    background: white;
    border: 2px solid rgba(139, 69, 19, 0.25);
  }
</style>
