---
import { loadProtocols, loadDomains, loadAffordances } from '@/lib/data'
import BaseLayout from '@/layouts/BaseLayout.astro'
import DisclaimerBanner from '@/components/sections/DisclaimerBanner.astro'
import MatrixTable from '@/components/islands/MatrixTable'
import ComparisonView from '@/components/islands/ComparisonView'
import { useTranslations } from '@/i18n'

const protocols = loadProtocols()
const domains = loadDomains()
const affordances = loadAffordances()

const locale = Astro.currentLocale ?? 'en'
const t = useTranslations(locale)
const prefix = locale !== 'en' ? `/${locale}` : ''

// --- JSON-LD ---
const siteBase = (Astro.site ?? new URL('https://openhaven.net')).toString().replace(/\/$/, '')
const canonicalUrl = `${siteBase}/prototype/matrix`

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  'name': t('matrixPage.jsonLdName'),
  'description': t('matrixPage.jsonLdDescription'),
  'url': canonicalUrl,
  'mainEntity': {
    '@type': 'ItemList',
    'name': t('matrixPage.jsonLdListName'),
    'numberOfItems': protocols.length,
    'itemListElement': protocols.map((protocol, index) => ({
      '@type': 'ListItem',
      'position': index + 1,
      'name': protocol.name,
      'url': `${siteBase}/prototype/protocols/${protocol.id}`,
    })),
  },
}

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': t('nav.home'), 'item': siteBase },
    { '@type': 'ListItem', 'position': 2, 'name': t('nav.matrix'), 'item': canonicalUrl },
  ],
}
---

<BaseLayout
  title={t('matrixPage.title') as string}
  description={t('matrixPage.description') as string}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify([jsonLd, breadcrumbLd])} />
  </Fragment>

  <main data-testid="matrix-page">
    <section class="section-padding">
      <div class="container">

        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="breadcrumb-nav" data-testid="breadcrumb">
          <ol class="breadcrumb-list">
            <li>
              <a href={`${prefix}/prototype`} class="breadcrumb-link" data-testid="breadcrumb-home">{t('nav.home')}</a>
            </li>
            <li aria-hidden="true" class="breadcrumb-sep">&gt;</li>
            <li aria-current="page"><span class="breadcrumb-current">{t('nav.matrix')}</span></li>
          </ol>
        </nav>

        <!-- Page Heading -->
        <div class="page-header">
          <h1 class="page-title">{t('matrixPage.pageTitle')}</h1>
          <p class="page-subtitle">{t('matrixPage.pageSubtitle')}</p>
        </div>

        <DisclaimerBanner
          message={t('disclaimer.alphaDemo') as string}
          variant="warning"
        />

        <!-- Matrix Table Card -->
        <div class="matrix-card">
          <MatrixTable
            client:load
            protocols={protocols}
            domains={domains}
            affordances={affordances}
            locale={locale}
          />
        </div>

      </div>
    </section>

    <section id="comparison" class="section-padding">
      <div class="container">
        <ComparisonView
          client:load
          protocols={protocols}
          domains={domains}
          affordances={affordances}
          locale={locale}
        />
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Breadcrumb — matches protocols/[id].astro */
  .breadcrumb-nav {
    margin-bottom: 1.25rem;
    font-size: 0.8125rem;
  }

  .breadcrumb-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    color: var(--color-brand-text);
    opacity: 0.7;
  }

  .breadcrumb-link {
    color: var(--color-brand-primary);
    text-decoration: none;
    min-height: 44px;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
  }

  .breadcrumb-link:hover {
    text-decoration: underline;
  }

  .breadcrumb-sep {
    opacity: 0.4;
  }

  .breadcrumb-current {
    color: var(--color-brand-text);
  }

  /* Page Header */
  .page-header {
    margin-bottom: 1.5rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-brand-primary);
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
  }

  @media (min-width: 640px) {
    .page-title {
      font-size: 2rem;
    }
  }

  .page-subtitle {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-brand-text);
    margin: 0;
    max-width: 60ch;
  }

  /* Matrix Card — matches hero-card / attributes-card pattern from detail page */
  .matrix-card {
    background: white;
    border: 2px solid rgba(139, 69, 19, 0.25);
    border-radius: 1rem;
    padding: 1.25rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  @media (min-width: 640px) {
    .matrix-card {
      padding: 1.5rem;
    }
  }
</style>
