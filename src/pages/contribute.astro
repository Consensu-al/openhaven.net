---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { useTranslations } from '@/i18n'

const locale = Astro.currentLocale ?? 'en'
const t = useTranslations(locale)

const FORM_URL = 'https://cryptpad.fr/form/#/2/form/view/xChgBL3ouQRbBqOdEkwt0W+sWc7XFcDV1EpZby1c6Hs/'
const FORM_EMBED_URL = 'https://cryptpad.fr/form/#/2/form/view/xChgBL3ouQRbBqOdEkwt0W+sWc7XFcDV1EpZby1c6Hs/embed/'
---

<BaseLayout
  title={t('contribute.pageTitle') as string}
  description={t('contribute.pageDescription') as string}
>
  <main data-testid="contribute-page">
    <section class="section-padding">
      <div class="container">

        <div class="page-header">
          <h1 class="page-title">{t('contribute.heading')}</h1>
        </div>

        <div class="intro-card">
          <p class="intro-text">{t('contribute.intro1')}</p>
          <p class="intro-text">{t('contribute.intro2')}</p>
        </div>

        <div class="form-section">
          <p class="form-note">
            {t('contribute.formNote')}{' '}
            <a
              href={FORM_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="form-link"
            >
              {t('contribute.formLinkText')}
            </a>
          </p>

          <div class="iframe-wrapper">
            <iframe
              src={FORM_EMBED_URL}
              title={t('contribute.iframeTitle') as string}
              style="width: 100%; height: 700px; border: none; display: block;"
            ></iframe>
          </div>
        </div>

      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 1.5rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-brand-primary);
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
  }

  @media (min-width: 640px) {
    .page-title {
      font-size: 2rem;
    }
  }

  .intro-card {
    background: white;
    border: 2px solid rgba(139, 69, 19, 0.25);
    border-radius: 1rem;
    padding: 1.25rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  @media (min-width: 640px) {
    .intro-card {
      padding: 1.5rem;
    }
  }

  .intro-text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-brand-text);
    margin: 0;
  }

  .form-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-note {
    font-size: 0.9375rem;
    color: var(--color-brand-text);
    margin: 0;
  }

  .form-link {
    color: var(--color-brand-primary);
    text-decoration: underline;
    font-weight: 500;
  }

  .form-link:hover {
    opacity: 0.8;
  }

  .iframe-wrapper {
    background: white;
    border: 2px solid rgba(139, 69, 19, 0.25);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }
</style>
