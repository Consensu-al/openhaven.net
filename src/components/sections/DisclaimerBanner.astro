---
/**
 * DisclaimerBanner — Redesigned to match the warm pill/badge aesthetic
 * used throughout the navigator (StepHeader badges, affordance chips, etc.)
 */

export interface Props {
  message: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const { message, ctaLabel, ctaHref } = Astro.props;
---

<section class="disclaimer-section">
  <div class="disclaimer-pill">
    <span class="disclaimer-badge">Alpha</span>
    <p class="disclaimer-text" set:html={message.replace('Alpha — ', '')} />
    {ctaLabel && ctaHref && (
      <a href={ctaHref} class="disclaimer-link">
        {ctaLabel}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    )}
  </div>
</section>

<style>
  .disclaimer-section {
    display: flex;
    justify-content: center;
    padding: 1.5rem 1rem;
    background: var(--color-brand-bg);
  }

  .disclaimer-pill {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    border-radius: 0.75rem;
    background: white;
    border: 2px solid rgba(139, 69, 19, 0.25);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    max-width: 48rem;
  }

  .disclaimer-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-brand-primary);
    background: var(--color-brand-accent-light);
    border: 1px solid rgba(139, 69, 19, 0.2);
    border-radius: 9999px;
    flex-shrink: 0;
  }

  .disclaimer-text {
    flex: 1;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-brand-text);
    margin: 0;
    opacity: 0.75;
  }

  .disclaimer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-brand-primary);
    text-decoration: none;
    border-bottom: none;
    flex-shrink: 0;
    transition: gap 0.15s ease;
  }

  .disclaimer-link:hover {
    gap: 0.5rem;
    border-bottom: none;
  }

  @media (max-width: 639px) {
    .disclaimer-pill {
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
