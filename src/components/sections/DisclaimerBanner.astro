---
export interface Props {
  message: string;
  variant?: 'error' | 'warning';
}

const { message, variant = 'error' } = Astro.props;
const isWarning = variant === 'warning';
---

<section class="disclaimer-section">
  <div class:list={['disclaimer-banner', { 'disclaimer-warning': isWarning }]}>
    <div class:list={['disclaimer-icon', { 'disclaimer-icon--warning': isWarning }]} aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/>
        <path d="M12 9v4"/><path d="M12 17h.01"/>
      </svg>
    </div>
    <p class:list={['disclaimer-text', { 'disclaimer-text--warning': isWarning }]} set:html={message} />
  </div>
</section>

<style>
  .disclaimer-section {
    display: flex;
    justify-content: center;
    padding: 1rem 1rem;
    background: var(--color-brand-bg);
  }

  .disclaimer-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    max-width: 1200px;
    padding: 0.875rem 1.25rem;
    border-radius: 0.5rem;
    background: #fef2f2;
    border: 2px solid #dc2626;
    box-shadow: 0 1px 4px rgba(220, 38, 38, 0.15);
  }

  .disclaimer-warning {
    background: #fff7ed;
    border-color: #ea580c;
    box-shadow: 0 1px 4px rgba(234, 88, 12, 0.15);
  }

  .disclaimer-icon {
    flex-shrink: 0;
    color: #dc2626;
    display: flex;
    align-items: center;
  }

  .disclaimer-icon--warning {
    color: #ea580c;
  }

  .disclaimer-text {
    flex: 1;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.5;
    color: #991b1b;
    margin: 0;
  }

  .disclaimer-text--warning {
    color: #9a3412;
  }

  @media (max-width: 639px) {
    .disclaimer-banner {
      flex-direction: row;
      align-items: flex-start;
    }
  }
</style>
