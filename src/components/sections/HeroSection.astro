---
/**
 * HeroSection — Harvested from v0-prototype hero-section.tsx
 * Full-viewport hero with CTA buttons and centered layout.
 * Adapt content/CTAs per page when using.
 *
 * Design tokens mapped to OpenHaven warm earth tones.
 * NOT wired into any page — reference component for future stories.
 */

export interface Props {
  badge?: string;
  title: string;
  highlight?: string;
  titleSuffix?: string;
  subtitle: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  badge,
  title,
  highlight,
  titleSuffix,
  subtitle,
  primaryCta,
  secondaryCta,
} = Astro.props;
---

<section class="hero-section">
  <div class="hero-inner">
    {badge && (
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        <span set:html={badge} />
      </div>
    )}

    <h1 class="hero-title">
      {title}{' '}
      {highlight && <span class="hero-highlight">{highlight}</span>}
      {titleSuffix && ` ${titleSuffix}`}
    </h1>

    <p class="hero-subtitle">{subtitle}</p>

    {(primaryCta || secondaryCta) && (
      <div class="hero-actions">
        {primaryCta && (
          <a href={primaryCta.href} class="btn btn-primary">{primaryCta.label}</a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn btn-outline">{secondaryCta.label}</a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .hero-section {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    padding: 4rem 1rem;
    background: linear-gradient(
      135deg,
      var(--color-brand-accent-light) 0%,
      var(--color-brand-blue-light) 100%
    );
  }

  .hero-inner {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .hero-inner {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-inner {
      padding: 0 2rem;
    }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    color: var(--color-mvp-text);
    background: var(--color-mvp-bg);
    border: 1px solid var(--color-mvp-border);
    border-radius: 9999px;
  }

  .hero-badge-dot {
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    background: var(--color-brand-primary);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-badge-dot {
      animation: none;
    }
  }

  .hero-title {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-brand-text);
    margin-bottom: 1.5rem;
  }

  .hero-highlight {
    color: var(--color-brand-primary);
  }

  .hero-subtitle {
    max-width: 40rem;
    margin: 0 auto 2.5rem;
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-brand-text);
    opacity: 0.8;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-mono);
    border-radius: 0.5rem;
    text-decoration: none;
    border: 2px solid transparent;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--color-brand-primary);
    color: var(--color-brand-bg);
    border-color: var(--color-brand-primary);
  }

  .btn-primary:hover {
    background: var(--color-brand-primary-dark);
    border-color: var(--color-brand-primary-dark);
    border-bottom-color: var(--color-brand-primary-dark);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-brand-primary);
    border-color: var(--color-brand-primary);
  }

  .btn-outline:hover {
    background: var(--color-brand-primary);
    color: var(--color-brand-bg);
    border-bottom-color: var(--color-brand-primary);
  }

  @media (min-width: 640px) {
    .hero-title {
      font-size: 3rem;
    }

    .hero-subtitle {
      font-size: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-title {
      font-size: 4rem;
    }
  }
</style>
