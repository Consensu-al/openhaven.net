---
import { useTranslations } from '@/i18n';

interface Props {
  locale?: string;
}

const locale = Astro.props.locale ?? Astro.currentLocale ?? 'en';
const t = useTranslations(locale);
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="footer-copyright">{t('footer.copyright')}</p>
    <p class="footer-attribution"></p>
    <a
      href={`${locale !== 'en' ? `/${locale}` : ''}/contribute`}
      class="footer-link"
    >
      {t('nav.contribute')}
    </a>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-brand-primary);
    color: var(--color-brand-bg);
    padding: 1.5rem 0;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.5rem;
  }

  .footer-copyright {
    font-size: 0.875rem;
    color: var(--color-brand-bg);
    margin: 0;
  }

  .footer-attribution {
    font-size: 0.875rem;
    color: var(--color-brand-bg);
    opacity: 0.85;
    margin: 0;
    flex: 1;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    min-height: 44px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-brand-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    border-radius: 4px;
    transition: border-color 0.2s ease, opacity 0.2s ease;
  }

  .footer-link:hover {
    border-bottom-color: var(--color-brand-accent);
    opacity: 0.9;
  }

  .footer-link:focus-visible {
    outline: 2px solid var(--color-brand-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .footer-attribution {
      flex: none;
    }
  }
</style>
