---
import LanguageSwitcher from '@/components/ui/LanguageSwitcher.astro';
import { useTranslations } from '@/i18n';

interface Props {
  locale?: string;
}

const locale = Astro.props.locale ?? Astro.currentLocale ?? 'en';
const t = useTranslations(locale);

const currentPath = Astro.url.pathname;
const prefix = locale !== 'en' ? `/${locale}` : '';

const exactMatchPaths = ['/prototype', '/brief'];
const isActive = (href: string) => {
  const fullHref = `${prefix}${href}`;
  return exactMatchPaths.includes(href)
    ? currentPath === fullHref || currentPath === `${fullHref}/`
    : currentPath.startsWith(fullHref);
};

const isHomepage = currentPath === '/' || currentPath === ''
  || currentPath === `${prefix}/` || currentPath === prefix;
const isBrief = currentPath === `${prefix}/brief` || currentPath === `${prefix}/brief/`;

const navLinks = (isHomepage || isBrief)
  ? [
      { href: '/brief', label: t('nav.brief') as string },
      { href: '/prototype', label: t('nav.navigatorPrototype') as string },
      { href: '/contribute', label: t('nav.contribute') as string },
    ]
  : [
      { href: '/brief', label: t('nav.brief') as string },
      { href: '/prototype', label: t('nav.home') as string },
      { href: '/prototype/matrix', label: t('nav.matrixPrototype') as string },
      { href: '/contribute', label: t('nav.contribute') as string },
    ];
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href={`${prefix}/`} class="nav-wordmark" aria-label="OpenHaven home">
      <span class="nav-logo-text">OpenHaven</span>
    </a>

    <ul class="nav-links" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={`${prefix}${href}`}
            class={`nav-link ${isActive(href) ? 'nav-link--active' : ''}`}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="nav-right">
      <LanguageSwitcher />

      <button
        id="nav-toggle"
        class="nav-toggle"
        aria-expanded="false"
        aria-controls="nav-mobile-menu"
        aria-label="Toggle navigation menu"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <div id="nav-mobile-menu" class="nav-mobile" hidden>
    <ul role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={`${prefix}${href}`}
            class={`nav-mobile-link ${isActive(href) ? 'nav-link--active' : ''}`}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
    <div class="nav-mobile-switcher">
      <LanguageSwitcher />
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.hidden = expanded;
    });
  }
</script>

<style>
  .site-nav {
    background-color: var(--color-brand-bg);
    border-bottom: 2px solid var(--color-brand-primary);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 56px;
  }

  .nav-wordmark {
    text-decoration: none;
    border-bottom: none;
    flex-shrink: 0;
  }

  .nav-wordmark:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .nav-logo-text {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-brand-primary);
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 0.25rem;
    flex: 1;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.75rem;
    min-height: 44px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-brand-text);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    border-radius: 4px 4px 0 0;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-brand-primary);
    border-bottom-color: var(--color-brand-accent);
  }

  .nav-link:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--color-brand-bg), 0 0 0 4px var(--color-focus-ring);
    border-radius: 4px;
  }

  .nav-link--active {
    color: var(--color-brand-primary);
    border-bottom-color: var(--color-brand-accent);
    font-weight: 600;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-left: auto;
  }

  /* Hamburger toggle — hidden on desktop */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: 1px solid var(--color-brand-primary);
    border-radius: 4px;
    padding: 8px;
    cursor: pointer;
    width: 44px;
    height: 44px;
    transition: background 0.2s;
  }

  .nav-toggle:hover {
    background-color: var(--color-brand-accent-light);
  }

  .nav-toggle:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 2px;
  }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 2px;
    background-color: var(--color-brand-primary);
    border-radius: 2px;
  }

  /* Mobile menu */
  .nav-mobile {
    border-top: 1px solid var(--color-brand-accent-light);
    background-color: var(--color-brand-bg);
    padding: 0.75rem 1.5rem 1rem;
  }

  .nav-mobile ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .nav-mobile-link {
    display: flex;
    align-items: center;
    padding: 0.625rem 0.75rem;
    min-height: 44px;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-brand-text);
    text-decoration: none;
    border-bottom: none;
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
  }

  .nav-mobile-link:hover {
    background-color: var(--color-brand-accent-light);
    color: var(--color-brand-primary);
  }

  .nav-mobile-link:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 2px;
  }

  .nav-mobile-link.nav-link--active {
    color: var(--color-brand-primary);
    font-weight: 600;
    background-color: var(--color-brand-accent-light);
  }

  .nav-mobile-switcher {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-brand-accent-light);
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }

    .nav-right > :global(.lang-switcher) {
      display: none;
    }

    .nav-toggle {
      display: flex;
    }
  }
</style>
